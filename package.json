{
  "name": "@anarchitecture-plugins/source",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/cli": "^12.0.0-alpha.5",
    "@nestjs/schematics": "^12.0.0-alpha.7",
    "@nx/eslint": "22.7.2",
    "@nx/eslint-plugin": "22.7.2",
    "@nx/jest": "22.7.2",
    "@nx/js": "22.7.2",
    "@nx/plugin": "22.7.2",
    "@nx/vite": "22.7.2",
    "@nx/web": "22.7.2",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.7.10",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.19",
    "@swc/jest": "~0.2.38",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@vitest/ui": "~4.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^30.0.2",
    "jest-environment-jsdom": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "jiti": "2.4.2",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "22.7.2",
    "pg": "^8.20.0",
    "prettier": "^2.6.2",
    "ts-jest": "^29.4.0",
    "ts-morph": "^22.0.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.3.0",
    "typeorm": "^0.3.28",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typeorm-ts-node-esm": "^0.3.20",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "verdaccio": "6.6.2",
    "vite": "^7.0.0",
    "vitest": "~4.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "yarn@4.14.1",
  "dependencies": {
    "@nestjs/typeorm": "^11.0.0",
    "@nx/devkit": "22.7.2",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^6.0.1"
  },
  "nx": {
    "includedScripts": [],
    "metadata": {
      "documentation": true,
      "ownership": {
        "team": "@anarchitects/platform"
      }
    },
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      },
      "repo-health": {
        "executor": "@anarchitects/nx-governance:repo-health",
        "options": {
          "profile": "frontend-layered",
          "output": "cli"
        },
        "metadata": {
          "description": "Run governance health assessment for the workspace."
        }
      },
      "repo-boundaries": {
        "executor": "@anarchitects/nx-governance:repo-boundaries",
        "options": {
          "profile": "frontend-layered",
          "output": "cli"
        },
        "metadata": {
          "description": "Run governance boundary checks for the workspace."
        }
      },
      "repo-ownership": {
        "executor": "@anarchitects/nx-governance:repo-ownership",
        "options": {
          "profile": "frontend-layered",
          "output": "cli"
        },
        "metadata": {
          "description": "Run governance ownership checks for the workspace."
        }
      },
      "repo-architecture": {
        "executor": "@anarchitects/nx-governance:repo-architecture",
        "options": {
          "profile": "frontend-layered",
          "output": "cli"
        },
        "metadata": {
          "description": "Run governance architecture checks for the workspace."
        }
      },
      "repo-snapshot": {
        "executor": "@anarchitects/nx-governance:repo-snapshot",
        "options": {
          "profile": "frontend-layered",
          "output": "cli"
        },
        "metadata": {
          "description": "Persist governance metric snapshots for drift and AI analysis."
        }
      },
      "repo-drift": {
        "executor": "@anarchitects/nx-governance:repo-drift",
        "options": {
          "output": "cli"
        },
        "metadata": {
          "description": "Compare recent governance snapshots and report drift signals."
        }
      },
      "repo-management-insights": {
        "executor": "@anarchitects/nx-governance:repo-management-insights",
        "options": {
          "profile": "frontend-layered",
          "output": "cli"
        },
        "metadata": {
          "description": "Render management-facing delivery-impact insights derived from governance signals."
        }
      },
      "repo-ai-management-insights": {
        "executor": "@anarchitects/nx-governance:repo-ai-management-insights",
        "options": {
          "profile": "frontend-layered",
          "output": "json"
        },
        "metadata": {
          "description": "Prepare deterministic AI management-insights payloads from delivery-impact assessments and governance trend context."
        }
      },
      "workspace-graph": {
        "executor": "@anarchitects/nx-governance:workspace-graph",
        "metadata": {
          "description": "Print workspace project/dependency counts from the Nx graph for diagnostic baselining."
        }
      },
      "workspace-conformance": {
        "executor": "@anarchitects/nx-governance:workspace-conformance",
        "options": {
          "conformanceJson": "dist/conformance-result.json"
        },
        "metadata": {
          "description": "Print Nx Conformance finding/error/warning counts from conformance JSON output."
        }
      },
      "governance-graph": {
        "executor": "@anarchitects/nx-governance:governance-graph",
        "options": {
          "format": "html",
          "outputPath": "dist/governance/graph.html"
        },
        "metadata": {
          "description": "Generate a governance-enriched graph artifact and static HTML viewer from the Nx Project Graph."
        }
      },
      "repo-ai-root-cause": {
        "executor": "@anarchitects/nx-governance:repo-ai-root-cause",
        "options": {
          "profile": "frontend-layered",
          "output": "json",
          "topViolations": 10
        },
        "metadata": {
          "description": "Prepare deterministic AI root-cause payloads from governance snapshots."
        }
      },
      "repo-ai-drift": {
        "executor": "@anarchitects/nx-governance:repo-ai-drift",
        "options": {
          "profile": "frontend-layered",
          "output": "json"
        },
        "metadata": {
          "description": "Prepare deterministic AI drift interpretation payloads from snapshot deltas and trend signals."
        }
      },
      "repo-ai-pr-impact": {
        "executor": "@anarchitects/nx-governance:repo-ai-pr-impact",
        "options": {
          "profile": "frontend-layered",
          "output": "json",
          "baseRef": "main",
          "headRef": "HEAD"
        },
        "metadata": {
          "description": "Prepare deterministic AI PR impact payloads from git diff and workspace dependency signals."
        }
      },
      "repo-ai-cognitive-load": {
        "executor": "@anarchitects/nx-governance:repo-ai-cognitive-load",
        "options": {
          "profile": "frontend-layered",
          "output": "json",
          "topProjects": 10
        },
        "metadata": {
          "description": "Prepare deterministic AI cognitive-load payloads from dependency fanout and coupling signals."
        }
      },
      "repo-ai-recommendations": {
        "executor": "@anarchitects/nx-governance:repo-ai-recommendations",
        "options": {
          "profile": "frontend-layered",
          "output": "json",
          "topViolations": 10
        },
        "metadata": {
          "description": "Prepare deterministic AI architecture recommendations from violations, dependencies, and trends."
        }
      },
      "repo-ai-smell-clusters": {
        "executor": "@anarchitects/nx-governance:repo-ai-smell-clusters",
        "options": {
          "profile": "frontend-layered",
          "output": "json",
          "topViolations": 10
        },
        "metadata": {
          "description": "Prepare deterministic AI smell-cluster analysis from violations and snapshot persistence signals."
        }
      },
      "repo-ai-refactoring-suggestions": {
        "executor": "@anarchitects/nx-governance:repo-ai-refactoring-suggestions",
        "options": {
          "profile": "frontend-layered",
          "output": "json",
          "topViolations": 10,
          "topProjects": 5
        },
        "metadata": {
          "description": "Prepare deterministic AI refactoring suggestions from hotspot, fanout, and persistent smell signals."
        }
      },
      "repo-ai-scorecard": {
        "executor": "@anarchitects/nx-governance:repo-ai-scorecard",
        "options": {
          "profile": "frontend-layered",
          "output": "json"
        },
        "metadata": {
          "description": "Prepare deterministic AI governance scorecards from health, violations, and drift trend signals."
        }
      },
      "repo-ai-onboarding": {
        "executor": "@anarchitects/nx-governance:repo-ai-onboarding",
        "options": {
          "profile": "frontend-layered",
          "output": "json",
          "topViolations": 10,
          "topProjects": 5
        },
        "metadata": {
          "description": "Prepare deterministic AI onboarding briefs from inventory, dependency, and governance hotspot signals."
        }
      }
    }
  }
}
