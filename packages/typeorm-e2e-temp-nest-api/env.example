# Choose one configuration mode:
# 1) DATABASE_URL
# 2) TYPEORM_* discrete variables
# Mixed mode is rejected.

# Mode 1: DATABASE_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/typeorm_e2e_temp_nest_api


# Mode 2: TYPEORM_* variables
TYPEORM_HOST=localhost
TYPEORM_PORT=5432
TYPEORM_USERNAME=postgres
TYPEORM_PASSWORD=postgres
TYPEORM_DATABASE=typeorm_e2e_temp_nest_api
TYPEORM_SCHEMA=public
TYPEORM_SSL=false
# TYPEORM_SSL can also be a JSON object:
# TYPEORM_SSL={"rejectUnauthorized":false}
TYPEORM_APPLICATION_NAME=typeorm_e2e_temp_nest_api-service
TYPEORM_CONNECT_TIMEOUT_MS=5000

