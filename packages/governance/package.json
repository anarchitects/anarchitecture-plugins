{
  "name": "@anarchitects/nx-governance",
  "version": "0.9.0",
  "description": "Nx governance plugin for workspace health, boundaries, ownership, and architecture reporting.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@anarchitecture-plugins/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./host": {
      "@anarchitecture-plugins/source": "./src/host-public-api.ts",
      "types": "./dist/host-public-api.d.ts",
      "import": "./dist/host-public-api.js",
      "default": "./dist/host-public-api.js"
    },
    "./plugin": {
      "@anarchitecture-plugins/source": "./src/plugin/index.ts",
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js",
      "default": "./dist/plugin/index.js"
    }
  },
  "bin": {
    "agov": "dist/standalone-cli/bin/agov.js"
  },
  "license": "Apache-2.0",
  "executors": "dist/index.json",
  "generators": "dist/index.json",
  "files": [
    "dist",
    "README.md",
    "!**/*.tsbuildinfo"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anarchitects/anarchitecture-plugins.git",
    "directory": "packages/governance"
  },
  "nx": {
    "name": "nx-governance",
    "metadata": {
      "documentation": true,
      "ownership": {
        "team": "@anarchitects/architecture"
      }
    },
    "plugins": [
      {
        "plugin": "dist/plugin/index.js"
      }
    ],
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "packages/governance/dist",
          "main": "packages/governance/src/index.ts",
          "tsConfig": "packages/governance/tsconfig.lib.json",
          "rootDir": "packages/governance/src",
          "generatePackageJson": false,
          "assets": [
            {
              "input": "./packages/governance/src",
              "glob": "**/!(*.ts)",
              "ignore": [
                "**/fixtures/**",
                "**/__fixtures__/**"
              ],
              "output": "."
            }
          ]
        }
      },
      "test": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "packages/governance/jest.config.cts",
          "passWithNoTests": true
        }
      }
    },
    "tags": [
      "type:plugin",
      "domain:governance"
    ]
  },
  "dependencies": {
    "@anarchitects/governance-adapter-nx": "workspace:*",
    "@anarchitects/governance-core": "0.0.1",
    "minimatch": "9.0.5",
    "tslib": "^2.6.2",
    "typescript": "~5.9.2",
    "yaml": "^2.8.1"
  },
  "peerDependencies": {
    "@nx/devkit": ">=19 <23",
    "nx": ">=19 <23"
  }
}
