{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/jest",
    "types": ["jest", "node"]
  },
  "include": [
    "jest.config.cts",
    "src/core/**/*.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "src/standalone-cli/**",
    "src/typescript-adapter/**",
    "src/manual-workspace/**"
  ],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
