{
  "name": "check-warning",
  "description": "Standalone agov check warning threshold fixture",
  "boundaryPolicySource": "profile",
  "layers": ["domain"],
  "allowedDomainDependencies": {
    "customer": ["order"],
    "order": [],
    "*": []
  },
  "ownership": {
    "required": true,
    "metadataField": "ownership"
  },
  "health": {
    "statusThresholds": {
      "goodMinScore": 85,
      "warningMinScore": 70
    }
  },
  "metrics": {
    "architectural-entropy": 1,
    "dependency-complexity": 1,
    "domain-integrity": 1,
    "ownership-coverage": 1,
    "documentation-completeness": 1,
    "layer-integrity": 1
  }
}
