{
  "name": "@anarchitects/nx-typeorm",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/src/index.js",
  "executors": "dist/src/index.json",
  "generators": "dist/src/index.json",
  "files": [
    "dist",
    "README.md",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "name": "nx-typeorm",
    "plugins": [
      {
        "plugin": "dist/src/plugins/typeorm.js"
      }
    ],
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "packages/typeorm/dist",
          "main": "packages/typeorm/src/index.ts",
          "tsConfig": "packages/typeorm/tsconfig.lib.json",
          "rootDir": "packages/typeorm/src",
          "generatePackageJson": false,
          "assets": [
            {
              "input": "./packages/typeorm/src",
              "glob": "**/!(*.ts)",
              "output": "."
            }
          ]
        }
      },
      "test": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "packages/typeorm/jest.config.cjs",
          "passWithNoTests": false
        }
      }
    },
    "tags": [
      "type:plugin",
      "domain: typeorm"
    ]
  },
  "peerDependencies": {
    "@nx/devkit": "^22.0.0",
    "nx": "22.0.1",
    "ts-morph": "^22.0.0",
    "ts-node": "10.9.1",
    "typeorm": "^0.3.20"
  },
  "dependencies": {
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "ts-morph": "^22.0.0"
  }
}
