{
  "name": "nx-nest-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "projectType": "application",
    "sourceRoot": "packages/nest-e2e/src",
    "metadata": {
      "documentation": true,
      "ownership": {
        "team": "@anarchitects/qa"
      }
    },
    "tags": [
      "type:e2e",
      "domain:nest"
    ],
    "implicitDependencies": [
      "nx-nest"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "packages/nest-e2e/jest.config.cts",
          "runInBand": true
        },
        "dependsOn": [
          "^build"
        ]
      }
    }
  }
}
